{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "image": {
      "default": "node-install-sandbox:latest",
      "type": "string"
    },
    "grants": {
      "default": {
        "ssh-agent": false,
        "claude": "none",
        "paths": [],
        "env": [],
        "envFiles": []
      },
      "type": "object",
      "properties": {
        "ssh-agent": {
          "default": false,
          "type": "boolean"
        },
        "claude": {
          "default": "none",
          "type": "string",
          "enum": [
            "none",
            "project",
            "home"
          ]
        },
        "paths": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "env": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "envFiles": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "ssh-agent",
        "claude",
        "paths",
        "env",
        "envFiles"
      ],
      "additionalProperties": false
    },
    "install": {
      "default": {
        "network": "allowlist",
        "frozen": false,
        "riskHints": "basic",
        "failOnRisk": false,
        "minReleaseAgeDays": 0,
        "minReleaseAgeExclude": [],
        "failOnAdvisory": false,
        "failOnDeprecated": true
      },
      "type": "object",
      "properties": {
        "network": {
          "default": "allowlist",
          "type": "string",
          "enum": [
            "none",
            "on",
            "allowlist"
          ]
        },
        "frozen": {
          "default": false,
          "type": "boolean"
        },
        "riskHints": {
          "default": "basic",
          "type": "string",
          "enum": [
            "off",
            "basic",
            "thorough"
          ]
        },
        "failOnRisk": {
          "default": false,
          "type": "boolean"
        },
        "minReleaseAgeDays": {
          "default": 0,
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "minReleaseAgeExclude": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failOnAdvisory": {
          "default": false,
          "type": "boolean"
        },
        "failOnDeprecated": {
          "default": true,
          "type": "boolean"
        }
      },
      "required": [
        "network",
        "frozen",
        "riskHints",
        "failOnRisk",
        "minReleaseAgeDays",
        "minReleaseAgeExclude",
        "failOnAdvisory",
        "failOnDeprecated"
      ],
      "additionalProperties": false
    },
    "egress": {
      "default": {
        "allow": [
          "npmjs.org",
          "npmjs.com"
        ]
      },
      "type": "object",
      "properties": {
        "allow": {
          "default": [
            "npmjs.org",
            "npmjs.com"
          ],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "allow"
      ],
      "additionalProperties": false
    },
    "run": {
      "default": {
        "network": "none",
        "ports": [],
        "devPorts": false
      },
      "type": "object",
      "properties": {
        "network": {
          "default": "none",
          "type": "string",
          "enum": [
            "none",
            "on",
            "allowlist"
          ]
        },
        "ports": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "devPorts": {
          "default": false,
          "type": "boolean"
        }
      },
      "required": [
        "network",
        "ports",
        "devPorts"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "image",
    "grants",
    "install",
    "egress",
    "run"
  ],
  "additionalProperties": false
}
